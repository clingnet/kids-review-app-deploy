# ============ 复制为 .env 后填写 ============

# ---- 运行模式 ----
# true = 不调真实模型，用内置模拟数据跑通链路（无 Key 也能用）
# false = 调真实模型（需填下面的 Key）
LLM_DRY_RUN=false

# ---- LLM Provider（OpenAI 兼容）----
# 推荐：OpenRouter，一个 Key 调 DeepSeek / Qwen-VL / Gemini 等所有模型
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 备选直连（按需）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 多模型兼容：OpenRouter 不同模型对 json_object 支持不一，默认关，靠提取兜底
USE_JSON_RESPONSE_FORMAT=false

# ---- 模型角色映射 provider:model_id ----
# 注意：OpenRouter 的 model_id 含 "/"；DeepSeek 在 OpenRouter 不收图片，故读图用 Qwen-VL
# 读图/提取（视觉，中文手写强）
VISION_MODEL=openrouter:qwen/qwen3-vl-235b-a22b-instruct
# 推理/分析/出题/讲解（DeepSeek 便宜且强）
REASON_MODEL=openrouter:deepseek/deepseek-v4-flash
# 手写识别兜底（不同家视觉模型）
VISION_FALLBACK_MODEL=openrouter:google/gemini-2.5-flash

# ---- 语音（AI 老师辅导，三期接入；走百炼/讯飞，OpenRouter 暂无语音）----
ASR_MODEL=bailian:paraformer-realtime-v2
TTS_MODEL=bailian:cosyvoice-v1

# ---- App ----
DATA_DIR=./data
MAX_IMAGE_EDGE=1600           # 上传图片压缩长边像素（降本）
JPEG_QUALITY=82

# 公网443访问密码的 bcrypt 哈希(caddy hash-password 生成),空则没密码保护
CADDY_AUTH_HASH=
